# Database configuration
DATABASE_URL=<Example: sqlite:///./data/secure.db>

# Data Transit Private Keys
PRIVATE_KEY_V1_PATH=<Path to private key file. Example: ./keys/private.pem>
PRIVATE_KEY_V2_PATH=<Path to private key file. Example: ./keys/private.pem>
PRIVATE_KEY_V3_PATH=<Path to private key file. Example: ./keys/private.pem>

# Blind Index HMAC Key
HMAC_KEY=<HMAC key> # example: cnbLhdtVO6g7RLhZMe1hE11c+16NmslcejuutnZx/0g=

# Data Encryption Keys
ENCRYPTION_KEY_K1=<Encryption key> # example: GUSTOZJ9RkCfDagEYfAvBo9QTgBQ5IE9CzMRTKYgXdI=
ENCRYPTION_KEY_K2=<Encryption key> # example: GUSTOZJ9RkCfDagEYfAvBo9QTgBQ5IE9CzMRTKYgXdI=
ENCRYPTION_KEY_K3=<Encryption key> # example: GUSTOZJ9RkCfDagEYfAvBo9QTgBQ5IE9CzMRTKYgXdI=
ENCRYPTION_KEY_VERSION=<Version> # k1, k2, k3, ...

